NODE_ENV=development
PORT=3000

# Prefer DATABASE_URL for hosted databases. For local development, use DB_*.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=dinesmart
DB_SSL=false

# Required in production. Use at least 32 random bytes.
JWT_SECRET=
SESSION_SECRET=
ADMIN_SIGNUP_KEY=

FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

EMAIL_PROVIDER=brevo
EMAIL_FROM=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
BREVO_API_KEY=
RESEND_API_KEY=

GITHUB_TOKEN=
GITHUB_MODELS_ENDPOINT=
PERSPECTIVE_API_KEY=
OPENAI_API_KEY=

MENU_SYNC_ENABLED=false
MENU_SYNC_INTERVAL_MS=900000
